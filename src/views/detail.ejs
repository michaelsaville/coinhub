<%- include('_head') %>
  <p><a href="javascript:history.back()">&larr; back</a></p>

  <h1><%= coin.year ?? '—' %> <%= coin.series ?? '(unassigned)' %> <%= coin.mint_code ?? '' %></h1>
  <p class="meta"><code><%= coin.serial %></code></p>

  <dl class="detail">
    <dt>Type</dt><dd><%= coin.type_name ?? '—' %></dd>
    <dt>Series</dt><dd><%= coin.series ?? '—' %></dd>
    <dt>Year</dt><dd><%= coin.year ?? '—' %></dd>
    <dt>Mint</dt><dd><%= coin.mint_code ? `${coin.mint_code} — ${coin.mint_name}` : '—' %></dd>
    <dt>Grade</dt><dd><%= coin.grade ?? '—' %> <% if (coin.category) { %><span class="muted">(<%= coin.category %>)</span><% } %></dd>
    <dt>Qty</dt><dd><%= coin.qty ?? 1 %></dd>
    <dt>Paid</dt><dd><%= coin.paid != null ? '$' + Number(coin.paid).toFixed(2) : '—' %></dd>
    <dt>Book</dt><dd><%= coin.book_value != null ? '$' + Number(coin.book_value).toFixed(2) : '—' %></dd>
    <% if (coin.slab_serial) { %>
      <dt>Slab</dt><dd><%= coin.grading_service ?? '' %> <%= coin.slab_serial %> <%= coin.grade_detail ?? '' %></dd>
    <% } %>
    <% if (coin.country_code && coin.country_code !== 'US') { %>
      <dt>Country</dt><dd><%= coin.country_code %></dd>
    <% } %>
    <% if (coin.comment_1) { %><dt>Note</dt><dd><%= coin.comment_1 %></dd><% } %>
    <% if (coin.comment_2) { %><dt>Note</dt><dd><%= coin.comment_2 %></dd><% } %>
    <% if (coin.photo_filename) { %><dt>Photo ref</dt><dd class="muted"><%= coin.photo_filename %></dd><% } %>
    <dt>Added</dt><dd class="muted"><%= new Date(coin.created_at).toISOString().slice(0,10) %></dd>
  </dl>

  <% if (attrs && attrs.length > 0) { %>
    <h2>Custom fields</h2>
    <form action="/coins/<%= coin.id %>/attributes" method="post" class="attr-form">
      <% attrs.forEach(a => { %>
        <label>
          <span><%= a.label %><% if (a.unit) { %> <em class="muted">(<%= a.unit %>)</em><% } %></span>
          <input
            type="<%= a.type === 'NUMBER' ? 'number' : a.type === 'DATE' ? 'date' : 'text' %>"
            <% if (a.type === 'NUMBER') { %>step="any" inputmode="decimal"<% } %>
            name="attr_<%= a.key %>"
            value="<%= a.value || '' %>"
            placeholder="<%= a.hint || '' %>" />
        </label>
      <% }) %>
      <div class="attr-actions">
        <button type="submit">Save fields</button>
        <a href="/fields" class="muted-link">manage fields →</a>
      </div>
    </form>
    <style>
      .attr-form { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 14px; margin: 10px 0 20px; }
      @media (max-width: 520px) { .attr-form { grid-template-columns: 1fr; } }
      .attr-form label { display: flex; flex-direction: column; }
      .attr-form label > span { font-size: 0.78rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }
      .attr-form label > span em { font-style: normal; text-transform: none; letter-spacing: 0; }
      .attr-form input { padding: 8px 10px; min-height: 40px; background: var(--panel); color: var(--fg); border: 1px solid var(--border); border-radius: 8px; font-size: 0.95rem; }
      .attr-form input:focus { outline: 2px solid var(--accent); outline-offset: -1px; border-color: var(--accent); }
      .attr-actions { grid-column: 1 / -1; display: flex; gap: 12px; align-items: center; }
      .attr-actions button { padding: 10px 18px; background: var(--accent); color: var(--bg); border: 0; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 0.9rem; }
      .muted-link { color: var(--muted); font-size: 0.85rem; }
    </style>
  <% } %>

  <h2>Purchases (<%= purchases.length %>)</h2>
  <% if (purchases.length === 0) { %>
    <p class="muted">No purchase history yet.</p>
  <% } else { %>
    <%
      const totalPaid = purchases.reduce((sum, p) => sum + (p.price ? Number(p.price) * (p.qty || 1) : 0), 0);
      const totalQty = purchases.reduce((sum, p) => sum + (p.qty || 1), 0);
    %>
    <p class="fine">
      <%= totalQty %> coin<%= totalQty === 1 ? '' : 's' %> purchased ·
      total spent <strong>$<%= totalPaid.toFixed(2) %></strong>
    </p>
    <table class="preview">
      <thead>
        <tr>
          <th>Date</th>
          <th>Qty</th>
          <th>Price</th>
          <th>Source</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <% purchases.forEach(p => { %>
          <tr>
            <td><%= p.purchase_date ? new Date(p.purchase_date).toISOString().slice(0,10) : '—' %></td>
            <td><%= p.qty ?? 1 %></td>
            <td><%= p.price != null ? '$' + Number(p.price).toFixed(2) : '—' %></td>
            <td class="muted"><%= p.source ?? '' %></td>
            <td class="muted"><%= p.notes ?? '' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
<%- include('_foot') %>
