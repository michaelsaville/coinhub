<%- include('_head') %>
  <div class="wizard-steps">
    <span class="active">1. Upload</span>
    <span>2. Map columns</span>
    <span>3. Preview</span>
    <span>4. Done</span>
  </div>

  <h1>Import coins</h1>
  <p class="meta">Drop in an Excel (.xlsx, .xlsm) or CSV file. The wizard reads the first sheet.</p>

  <% if (error) { %>
    <div class="error-banner"><%= error %></div>
  <% } %>

  <form action="/import" method="post" enctype="multipart/form-data">
    <label class="dropzone" id="drop">
      <input type="file" name="file" accept=".xlsx,.xlsm,.xls,.csv" required onchange="document.getElementById('chosen').textContent = this.files[0]?.name || '';" />
      <div style="font-size: 1.05rem; color: var(--fg); margin-bottom: 4px;">Click to choose a file</div>
      <div>or drag and drop here</div>
      <div id="chosen" style="margin-top: 8px; color: var(--accent); font-weight: 600;"></div>
    </label>
    <p class="fine">Up to 10 MB. The first sheet is used. Headers auto-detected.</p>
    <div class="btn-row">
      <button type="submit" class="btn">Continue →</button>
      <a href="/" class="btn btn-secondary">Cancel</a>
    </div>
  </form>

  <script>
    // Tiny drop-zone enhancement: accept dragged files into the hidden input.
    const drop = document.getElementById('drop');
    const input = drop.querySelector('input[type=file]');
    ['dragenter','dragover'].forEach(ev => drop.addEventListener(ev, e => {
      e.preventDefault();
      drop.style.borderColor = 'var(--accent)';
    }));
    ['dragleave','drop'].forEach(ev => drop.addEventListener(ev, e => {
      e.preventDefault();
      drop.style.borderColor = '';
    }));
    drop.addEventListener('drop', e => {
      if (e.dataTransfer?.files?.length) {
        input.files = e.dataTransfer.files;
        input.dispatchEvent(new Event('change'));
      }
    });
  </script>
<%- include('_foot') %>
